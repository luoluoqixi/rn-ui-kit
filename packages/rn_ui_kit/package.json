{
  "name": "rn_ui_kit",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "React Native UI kit with core components and debug tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/luoluoqixi/rn_ui_kit.git"
  },
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./core": {
      "react-native": "./src/core.ts",
      "types": "./src/core.ts",
      "default": "./src/core.ts"
    },
    "./debug": {
      "react-native": "./src/debug.ts",
      "types": "./src/debug.ts",
      "default": "./src/debug.ts"
    },
    "./initialize": {
      "react-native": "./src/initialize.ts",
      "types": "./src/initialize.ts",
      "default": "./src/initialize.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "rn_ui_kit_core": "workspace:*",
    "rn_ui_kit_debug": "workspace:*"
  },
  "devDependencies": {
    "typescript": "=5.9.2"
  }
}
