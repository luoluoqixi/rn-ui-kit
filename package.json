{
  "name": "rn_ui_kit_workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "typecheck": "bun run --cwd packages/rn_ui_kit typecheck && bun run --cwd examples/app typecheck",
    "doctor": "bun run --cwd packages/rn_ui_kit doctor",
    "sync-patches": "bun packages/rn_ui_kit/scripts/sync-patches.mjs --cwd examples/app --path-root ."
  }
}
